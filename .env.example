# Flask Logistics Management API - Environment Configuration Template
# Copy this file to .env and update with your actual values

# ========== Flask Settings ==========
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-secret-key-change-in-production

# ========== Database Configuration ==========
# PostgreSQL database URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/logistics_db

# Development database (optional, separate from production)
DEV_DATABASE_URI=postgresql://postgres:password@localhost:5432/logistics_dev

# ========== JWT Configuration ==========
# Secret key for JWT token signing
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Token expiration times (in seconds)
JWT_ACCESS_TOKEN_EXPIRES=3600          # 1 hour
JWT_REFRESH_TOKEN_EXPIRES=2592000      # 30 days

# ========== Redis Configuration ==========
# Redis connection URL for caching and sessions
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ========== Email Configuration ==========
# SMTP settings for email notifications
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_USE_TLS=True
MAIL_DEFAULT_SENDER=noreply@logistics-api.com

# ========== Logging Configuration ==========
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ========== API Configuration ==========
# API title and version
API_TITLE=Logistics Management API
API_VERSION=1.0.0

# ========== Pagination Defaults ==========
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ========== Security Settings ==========
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Session cookie settings
SESSION_COOKIE_SECURE=False          # Set to True in production with HTTPS
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# ========== Rate Limiting ==========
# Rate limit settings
RATELIMIT_ENABLED=True
RATELIMIT_DEFAULT=100/hour

# ========== File Upload Configuration ==========
# Maximum upload size in MB
MAX_UPLOAD_SIZE=50
UPLOAD_FOLDER=./uploads

# ========== SMS Configuration (if using Twilio) ==========
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# ========== AWS Configuration (if using cloud services) ==========
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# ========== External Services ==========
# Google Maps API (for distance/routing calculations)
GOOGLE_MAPS_API_KEY=your-api-key

# ========== Pagination and Limits ==========
# Default items per page
ITEMS_PER_PAGE=20

# Maximum query results
MAX_QUERY_RESULTS=1000

# ========== Development Settings ==========
# Set to True to enable debug mode (development only)
DEBUG=True

# Set to True to enable template auto-reload
TEMPLATES_AUTO_RELOAD=True
